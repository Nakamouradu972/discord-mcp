# Discord bot token (required). Create a bot at https://discord.com/developers/applications
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN

# Optional default guild (server) id used when a tool call omits guildId
DISCORD_GUILD_ID=OPTIONAL_DEFAULT_SERVER_ID

# Optional: actor name recorded in the local audit log (defaults to "mcp")
DISCORD_MCP_ACTOR=

# Optional: path to the local audit log file (defaults to ./audit/audit-log.jsonl)
DISCORD_MCP_AUDIT_FILE=

# Optional: set to "false" to make write tools execute immediately instead of
# defaulting to dry-run. Individual calls can always override via the dryRun arg.
DISCORD_MCP_DRY_RUN_DEFAULT=

# --- HTTP transport security (build/app.js only) ---------------------------
# Bearer token required in the Authorization header on /mcp. Empty = NO AUTH
# (only safe bound to localhost behind a trusted reverse proxy). Set this
# before exposing the endpoint remotely.
DISCORD_MCP_AUTH_TOKEN=

# Interface the HTTP server binds to (default 127.0.0.1). Keep it on loopback
# and put a TLS reverse proxy in front; use 0.0.0.0 only inside an isolated
# Docker network.
DISCORD_MCP_BIND=

# Comma-separated allow-lists for DNS-rebinding protection. Empty = allow any.
DISCORD_MCP_ALLOWED_HOSTS=
DISCORD_MCP_ALLOWED_ORIGINS=

# --- Real-time gateway worker + event queue (Option B) ---------------------
# Set to "true" to keep a gateway connection that defers interactions (<3s)
# and enqueues events for the autonomous runner (poll_events tool). Requires a
# valid DISCORD_TOKEN. Only ONE process may enable this per bot token.
DISCORD_MCP_EVENTS=

# Path to the SQLite event-queue file (default ./audit/events.sqlite).
DISCORD_MCP_QUEUE_FILE=

# Which events to enqueue (defaults: interactions on, mentions on).
DISCORD_MCP_EVENTS_INTERACTIONS=
DISCORD_MCP_EVENTS_MENTIONS=
# Restrict mention capture to these channel ids (comma-separated; empty = any).
DISCORD_MCP_EVENTS_CHANNELS=
