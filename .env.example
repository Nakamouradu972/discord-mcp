# Discord bot token (required). Create a bot at https://discord.com/developers/applications
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN

# Optional default guild (server) id used when a tool call omits guildId
DISCORD_GUILD_ID=OPTIONAL_DEFAULT_SERVER_ID

# Optional: actor name recorded in the local audit log (defaults to "mcp")
DISCORD_MCP_ACTOR=

# Optional: path to the local audit log file (defaults to ./audit/audit-log.jsonl)
DISCORD_MCP_AUDIT_FILE=

# Optional: set to "false" to make write tools execute immediately instead of
# defaulting to dry-run. Individual calls can always override via the dryRun arg.
DISCORD_MCP_DRY_RUN_DEFAULT=
